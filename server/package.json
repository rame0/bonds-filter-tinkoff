{
  "name": "bonds-filter-tinkoff-server",
  "version": "0.3.0",
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "bun ./node_modules/moleculer/bin/moleculer-runner.js --hot --config moleculer.config.ts src/services/{**,**/**,**/**/**}/*.service.ts",
    "start": "bun ./node_modules/.bin/moleculer-runner --config dist/moleculer.config.js dist/src/services/{**,**/**,**/**/**}/*.service.js",
    "cli": "moleculer connect NATS",
    "ci": "bun test --watch",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "lint": "eslint --ext .js,.ts .",
    "typeorm": "bun run scripts/typeorm-run.ts",
    "migration:generate": "bun run scripts/typeorm-run.ts migration:generate -p"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.32.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-prefer-arrow": "^1.2.2",
    "jaeger-client": "^3.19.0",
    "moleculer-repl": "^0.7.3",
    "typeorm": "^0.3.28",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@kubernetes/client-node": "^0.16.3",
    "@tinkoff/invest-js": "^1.27.1-RC4",
    "axios": "^1.4.0",
    "cbor-x": "^1.5.3",
    "dotenv": "^16.3.1",
    "file-system-cache": "^2.4.4",
    "ioredis": "^5.3.2",
    "moleculer": "^0.14.28",
    "moleculer-cron": "^0.0.2",
    "moleculer-db": "^0.8.24",
    "moleculer-web": "^0.10.5",
    "moment": "^2.29.4",
    "nats": "^2.15.1"
  },
  "engines": {
    "bun": ">=1.3.7"
  },
  "engineStrict": true
}
